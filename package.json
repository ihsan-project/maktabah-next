{
  "name": "maktabah",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "functions",
    "quran_loader"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "functions": "npm run serve -w maktabah-functions",
    "functions:deploy": "npm run deploy -w maktabah-functions",
    "functions:logs": "npm run logs -w maktabah-functions",
    "loader:load-opensearch": "npm run load-elastic -w quran-elasticsearch-loader",
    "loader:load-storage": "npm run load-storage -w quran-elasticsearch-loader",
    "loader:reorder": "npm run reorder -w quran-elasticsearch-loader",
    "loader:decode": "npm run decode -w quran-elasticsearch-loader",
    "build:firebase": "next build && cp -r .next functions/",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npm run build:firebase && firebase deploy",
    "deploy:hosting": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:functions": "npm run build:firebase && firebase deploy --only functions"
  },
  "dependencies": {
    "@opensearch-project/opensearch": "^2.6.0",
    "firebase": "^10.6.0",
    "mixpanel-browser": "^2.47.0",
    "next": "^14.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-quill": "^2.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/mixpanel-browser": "^2.38.1",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-config-next": "^14.0.3",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2"
  }
}
